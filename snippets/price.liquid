{%- liquid
  assign target = product
  assign compare_at_price = target.compare_at_price
  assign price = target.price | default: 1999
  assign available = target.available | default: true
  assign money_price = price | money
-%}
<div class="price{% if compare_at_price > price and available %} price--on-sale{% endif %}">
  <dl>
    {%- if compare_at_price > price and available -%}
      <div class="price__sale"><dd><span class="price-item price-item--sale">{{ money_price }}</span></dd></div>
      <div class="price__compare"><dd><s class="price-item price-item--regular">{{ compare_at_price | money }}</s></dd></div>
    {%- else -%}
      <div class="price__regular"><dd><span class="price-item price-item--regular">{{ money_price }}</span></dd></div>
    {%- endif -%}
  </dl>
</div>
