<div class="rating" aria-hidden="true">
  {%- for i in (1..5) -%}
    <svg class="star{% if rating >= i %} star--full{% elsif rating > i | minus: 1 %} star--half{% else %} star--empty{% endif %}" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
      <path d="M7 1l1.545 3.13 3.455.502-2.5 2.436.59 3.44L7 8.885 3.91 10.508l.59-3.44L2 4.632l3.455-.502L7 1z" fill="{% if rating >= i %}currentColor{% else %}none{% endif %}" stroke="currentColor" stroke-width="0.75"/>
    </svg>
  {%- endfor -%}
</div>
