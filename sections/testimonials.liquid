{% comment %}
  Section: Testimonials Pro
  Multi-block testimonials with star ratings, customer photos,
  auto-rotating carousel, and verified purchase badge.
{% endcomment %}

{%- liquid
  assign block_count = section.blocks.size
  assign autoplay = section.settings.autoplay
  assign autoplay_speed = section.settings.autoplay_speed | times: 1000
-%}

<section
  id="testimonials-{{ section.id }}"
  class="testimonials page-width section-{{ section.id }}-padding"
  data-section-id="{{ section.id }}"
>
  {%- if section.settings.heading != blank -%}
    <div class="testimonials__header">
      <h2 class="testimonials__heading">{{ section.settings.heading | escape }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="testimonials__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if block_count == 0 -%}
    <div class="testimonials__placeholder">
      <p>Add testimonial blocks in the theme editor.</p>
    </div>
  {%- else -%}
    <div
      class="testimonials__slider"
      data-autoplay="{{ autoplay }}"
      data-speed="{{ autoplay_speed }}"
      data-per-view="{{ section.settings.per_view }}"
      role="region"
      aria-label="{{ section.settings.heading | default: 'Testimonials' | escape }}"
    >
      <div class="testimonials__track" id="testimonials-track-{{ section.id }}">
        {%- for block in section.blocks -%}
          <div
            class="testimonial-card testimonial-card--{{ section.settings.card_style }}"
            {{ block.shopify_attributes }}
            role="group"
            aria-label="Testimonial {{ forloop.index }} of {{ block_count }}"
          >
            <div class="testimonial-card__rating" aria-label="{{ block.settings.rating }} out of 5 stars">
              {%- for i in (1..5) -%}
                <span class="star{% if i <= block.settings.rating %} star--filled{% endif %}" aria-hidden="true">★</span>
              {%- endfor -%}
            </div>

            {%- if block.settings.quote != blank -%}
              <blockquote class="testimonial-card__quote">
                <p>{{ block.settings.quote | escape }}</p>
              </blockquote>
            {%- endif -%}

            <div class="testimonial-card__author">
              {%- if block.settings.author_image != blank -%}
                <div class="testimonial-card__author-image">
                  {{
                    block.settings.author_image
                    | image_url: width: 80
                    | image_tag:
                      loading: 'lazy',
                      widths: '40, 80',
                      sizes: '40px',
                      class: 'testimonial-card__avatar'
                  }}
                </div>
              {%- else -%}
                <div class="testimonial-card__author-initials" aria-hidden="true">
                  {{ block.settings.author_name | slice: 0, 1 | upcase }}
                </div>
              {%- endif -%}
              <div class="testimonial-card__author-info">
                {%- if block.settings.author_name != blank -%}
                  <span class="testimonial-card__author-name">{{ block.settings.author_name | escape }}</span>
                {%- endif -%}
                {%- if block.settings.author_location != blank -%}
                  <span class="testimonial-card__author-location">{{ block.settings.author_location | escape }}</span>
                {%- endif -%}
                {%- if block.settings.verified_purchase -%}
                  <span class="testimonial-card__verified">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M10 3L5 8.5 2 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="6" cy="6" r="5.25" stroke="currentColor" stroke-width="1.5"/></svg>
                    Verified Purchase
                  </span>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- if block_count > section.settings.per_view -%}
        <div class="testimonials__controls">
          <button class="testimonials__prev" aria-label="Previous testimonials" data-prev>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12 4L6 10L12 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="testimonials__dots" role="tablist" aria-label="Testimonial navigation">
            {%- for block in section.blocks -%}
              <button class="testimonial-dot{% if forloop.first %} testimonial-dot--active{% endif %}" role="tab" aria-selected="{{ forloop.first }}" data-index="{{ forloop.index0 }}" aria-label="Testimonial {{ forloop.index }}"></button>
            {%- endfor -%}
          </div>
          <button class="testimonials__next" aria-label="Next testimonials" data-next>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M8 4L14 10L8 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
</style>

{% schema %}
{
  "name": "Testimonials Pro",
  "tag": "section",
  "class": "section-testimonials",
  "max_blocks": 20,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Card Style",
      "options": [
        { "value": "minimal", "label": "Minimal" },
        { "value": "bordered", "label": "Bordered" },
        { "value": "shadowed", "label": "Shadowed" }
      ],
      "default": "bordered"
    },
    {
      "type": "range",
      "id": "per_view",
      "label": "Cards per View (desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay Speed (seconds)",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "name": "Testimonial",
      "type": "testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "This is an outstanding product. Highly recommend to everyone!"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Customer Name",
          "default": "Happy Customer"
        },
        {
          "type": "text",
          "id": "author_location",
          "label": "Location"
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Customer Photo"
        },
        {
          "type": "checkbox",
          "id": "verified_purchase",
          "label": "Verified Purchase",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials Pro",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "Absolutely love this product. The quality exceeded my expectations.",
            "author_name": "Sarah M.",
            "author_location": "New York, USA"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Fast shipping, great packaging, and the product is exactly as described.",
            "author_name": "James T.",
            "author_location": "London, UK"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Customer service was incredibly responsive. Will definitely buy again.",
            "author_name": "Priya K.",
            "author_location": "Sydney, AU"
          }
        }
      ]
    }
  ]
}
{% endschema %}
